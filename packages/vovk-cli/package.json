{
  "name": "vovk-cli",
  "version": "0.0.1-beta.86",
  "description": "CLI tool for managing Vovk.ts projects",
  "files": [
    "dist",
    "client-templates",
    "module-templates"
  ],
  "bin": {
    "vovk": "./dist/index.mjs"
  },
  "main": "./dist/index.mjs",
  "type": "module",
  "types": "./dist/index.d.mts",
  "prefix": ".",
  "scripts": {
    "build": "rm -rf dist tsconfig.build.tsbuildinfo && tsc -P tsconfig.build.json",
    "postbuild": "chmod +x ./dist/index.mjs",
    "pre-test": "npm run build && npm run clear-test-cache",
    "test-only": "npm run pre-test && node --experimental-transform-types --experimental-strip-types --experimental-vm-modules --test --test-only test/spec/**/*.mts",
    "test": "npm run pre-test && node --experimental-transform-types --experimental-strip-types --experimental-vm-modules --test --test-concurrency=1 test/spec/**/*.mts",
    "tsc": "tsc --noEmit",
    "ncu": "npm-check-updates -u -x commander,node-pty",
    "npm-publish": "npm publish",
    "clear-test-cache": "rm -rf ./tmp_*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/finom/vovk.git"
  },
  "keywords": [
    "nextjs",
    "router",
    "cli",
    "vovk"
  ],
  "author": "Andrey Gubanov",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/finom/vovk/issues"
  },
  "homepage": "https://vovk.dev",
  "peerDependencies": {
    "vovk": "^3.0.0-beta.142",
    "vovk-ajv": "^0.0.0-beta.23",
    "vovk-client": "^0.0.4-beta.24",
    "vovk-python": "^0.0.1-beta.13",
    "vovk-rust": "^0.0.1-beta.15"
  },
  "optionalDependencies": {
    "@rolldown/binding-linux-x64-gnu": "1.0.0-rc.6"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@inquirer/prompts": "^8.3.0",
    "@npmcli/package-json": "^7.0.5",
    "@types/json-schema": "^7.0.15",
    "@types/lodash": "^4.17.24",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "clone-deep": "^4.0.1",
    "commander": "^13.1.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "ejs": "^4.0.1",
    "get-tsconfig": "^4.13.6",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "inflection": "^3.0.2",
    "jsonc-parser": "^3.3.1",
    "lodash": "^4.17.23",
    "loglevel": "^1.9.2",
    "openapi3-ts": "^4.5.0",
    "pluralize": "^8.0.0",
    "prettier": "^3.8.1",
    "tar-stream": "^3.1.7",
    "ts-morph": "^27.0.2",
    "type-fest": "^5.4.4",
    "undici": "^7.22.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/concat-stream": "^2.0.3",
    "@types/ejs": "^3.1.5",
    "@types/js-yaml": "^4.0.9",
    "@types/npmcli__package-json": "^4.0.4",
    "@types/pluralize": "^0.0.33",
    "@types/tar-stream": "^3.1.4",
    "concat-stream": "^2.0.0",
    "create-next-app": "^16.1.6",
    "http-server": "^14.1.1",
    "node-pty": "0.10.1",
    "tsdown": "^0.20.3",
    "zod": "^4.3.6"
  }
}